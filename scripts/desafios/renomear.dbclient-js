db("aula").collection("personagens").aggregate([
  {
    $project: {
      "nome completo": "$nome",
      idade: 1,
      ilha: 1,
      _id: 1
    }
  }
])

db("aula").collection("personagens").aggregate([
  {
    $addFields: {
      "nome completo": "$nome"
    }
  },
  {
    $unset: "nome"
  }
]);